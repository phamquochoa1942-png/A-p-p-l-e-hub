-- ========== LOGIC GOM QUÁI (LẤY TỪ CODE BẠN) ==========
function BringMobFunction()
    spawn(function()
        while _G.AutoFarmNearest do task.wait() -- Chạy khi bật Farm Nearest
            if _G.BringMob then
                pcall(function()
                    -- Lấy vị trí dưới chân bạn (cách khoảng 5 studs để không bị kẹt)
                    local MyPos = game.Players.LocalPlayer.Character.HumanoidRootPart.Position
                    local TargetPos = MyPos + Vector3.new(0, -5, 0) 

                    for i, v in pairs(game:GetService("Workspace").Enemies:GetChildren()) do
                        -- Kiểm tra nếu là quái vật, còn sống và trong khoảng cách cho phép
                        if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v:FindFirstChild("HumanoidRootPart") then
                            if (v.HumanoidRootPart.Position - MyPos).Magnitude <= _G.DistanceMob then
                                
                                -- Vô hiệu hóa va chạm để quái không đẩy bạn đi
                                v.HumanoidRootPart.CanCollide = false
                                
                                -- Gom quái về vị trí mục tiêu
                                v.HumanoidRootPart.CFrame = CFrame.new(TargetPos)
                                
                                -- Tắt AI của quái (tùy chọn để quái đứng yên)
                                if v.Humanoid:FindFirstChild("Animator") then
                                    v.Humanoid.Animator:Destroy()
                                end
                            end
                        end
                    end
                end)
            end
        end
    end)
end

-- ========== LOGIC AUTO QUEST BLOX FRUIT ==========
function AutoQuestFunction()
    spawn(function()
        while _G.AutoFarmNearest do task.wait(2)
            if _G.AutoQuest then
                pcall(function()
                    local player = game.Players.LocalPlayer
                    local character = player.Character
                    if not character then return end
                    
                    -- Kiểm tra xem đã có nhiệm vụ chưa
                    local hasQuest = false
                    local questData = player:FindFirstChild("Quest")
                    if questData then
                        hasQuest = true
                    end
                    
                    -- Nếu chưa có nhiệm vụ thì tìm NPC để nhận
                    if not hasQuest then
                        local MyPos = character.HumanoidRootPart.Position
                        local questNPC = nil
                        
                        -- Tìm NPC Quest Giver trong Workspace
                        for _, v in pairs(game.Workspace:GetChildren()) do
                            if v.Name == _G.QuestNPC or v.Name == "Quest Giver" then
                                if v:FindFirstChild("HumanoidRootPart") then
                                    questNPC = v
                                    break
                                end
                            end
                        end
                        
                        -- Nếu không tìm thấy, tìm trong các Island
                        if not questNPC then
                            local islands = {"Marine", "Pirate", "Desert", "Sky", "Magma", "Ice", "Snow", "Jungle"}
                            for _, island in pairs(islands) do
                                local islandFolder = game.Workspace:FindFirstChild(island)
                                if islandFolder then
                                    for _, npc in pairs(islandFolder:GetChildren()) do
                                        if npc.Name == "Quest Giver" or npc.Name == _G.QuestNPC then
                                            if npc:FindFirstChild("HumanoidRootPart") then
                                                questNPC = npc
                                                break
                                            end
                                        end
                                    end
                                end
                                if questNPC then break end
                            end
                        end
                        
                        -- Nếu tìm thấy NPC
                        if questNPC and questNPC.HumanoidRootPart then
                            local distance = (questNPC.HumanoidRootPart.Position - MyPos).Magnitude
                            
                            -- Nếu NPC trong khoảng cách 50 studs
                            if distance <= 50 then
                                -- Gửi RemoteEvent để nhận nhiệm vụ (cách của Blox Fruit)
                                local remote = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes")
                                if remote then
                                    local questRemote = remote:FindFirstChild("Quest")
                                    if questRemote then
                                        questRemote:FireServer(questNPC)
                                        task.wait(0.5)
                                    end
                                end
                                
                                -- Click vào NPC nếu có ClickDetector
                                local clickDetector = questNPC.HumanoidRootPart:FindFirstChild("ClickDetector")
                                if clickDetector then
                                    clickDetector:Click()
                                    task.wait(0.5)
                                end
                            else
                                -- Di chuyển đến gần NPC
                                character.HumanoidRootPart.CFrame = CFrame.new(questNPC.HumanoidRootPart.Position + Vector3.new(0, 0, 5))
                                task.wait(1)
                            end
                        end
                    else
                        -- Nếu đã có nhiệm vụ, kiểm tra xem đã hoàn thành chưa
                        local completed = false
                        local required = questData:FindFirstChild("Required") or questData:FindFirstChild("Needed")
                        local current = questData:FindFirstChild("Current") or questData:FindFirstChild("Progress")
                        
                        if required and current then
                            if current.Value >= required.Value then
                                completed = true
                            end
                        end
                        
                        -- Nếu hoàn thành, tìm NPC để nộp nhiệm vụ
                        if completed then
                            local questNPC = nil
                            for _, v in pairs(game.Workspace:GetChildren()) do
                                if v.Name == _G.QuestNPC or v.Name == "Quest Giver" then
                                    if v:FindFirstChild("HumanoidRootPart") then
                                        questNPC = v
                                        break
                                    end
                                end
                            end
                            
                            if questNPC then
                                local MyPos = character.HumanoidRootPart.Position
                                local distance = (questNPC.HumanoidRootPart.Position - MyPos).Magnitude
                                
                                if distance <= 50 then
                                    local remote = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes")
                                    if remote then
                                        local questRemote = remote:FindFirstChild("Quest")
                                        if questRemote then
                                            questRemote:FireServer(questNPC)
                                            task.wait(0.5)
                                        end
                                    end
                                else
                                    character.HumanoidRootPart.CFrame = CFrame.new(questNPC.HumanoidRootPart.Position + Vector3.new(0, 0, 5))
                                    task.wait(1)
                                end
                            end
                        end
                    end
                end)
            end
        end
    end)
end

