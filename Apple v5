-- --- TAB MUSIC (GIỮ LOGIC CỦA BẠN) ---
local currentSound = nil
local MusicGroup = Tabs.Music:AddSection("🎵 Music Player")

local songs = {
    {"Mặc Vẩn Quy Kỳ", "126846792948717"},
    {"Poker face", "92706949906032"},
    {"Passo", "136729917310719"}
}

for _, song in ipairs(songs) do
    MusicGroup:AddButton({
        Title = "🎵 " .. song[1],
        Callback = function()
            if currentSound then currentSound:Destroy() end
            currentSound = Instance.new("Sound", workspace)
            currentSound.SoundId = "rbxassetid://" .. song[2]
            currentSound.Looped = true
            currentSound:Play()
            Fluent:Notify({ Title = "Music", Content = "Đang phát: " .. song[1], Duration = 2 })
        end
    })
end

