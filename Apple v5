-- Vòng lặp Auto Quest (chạy riêng)
spawn(function()
    while true do
        task.wait(3)
        
        if _G.AutoFarm and _G.AutoQuest then
            pcall(function()
                local currentLevel = GetPlayerLevel()
                local targetNPC = GetNPCByLevel(currentLevel)
                
                -- Kiểm tra nhiệm vụ
                local hasQuest = HasQuest()
                
                if not hasQuest then
                    -- Chưa có nhiệm vụ -> nhận
                    AcceptQuest(targetNPC)
                    task.wait(1)
                else
                    -- Đã có nhiệm vụ -> kiểm tra hoàn thành
                    if _G.AutoFinishQuest then
                        local isComplete = CheckQuestProgress()
                        if isComplete then
                            FinishQuest()
                            task.wait(1)
                        end
                    end
                end
            end)
        end
    end
end)

