-- Vòng lặp Auto Quest
spawn(function()
    while true do
        task.wait(2)
        
        if _G.AutoFarmNearest and _G.AutoQuest then
            pcall(function()
                local currentLevel = GetPlayerLevel()
                local targetNPC, targetArea = GetNPCByLevel(currentLevel)
                
