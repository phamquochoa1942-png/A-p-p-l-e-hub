local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "🍎 Apple Hub | V5 Banana Killer (GOD)",
   LoadingTitle = "Apple Hub V5 - Loading...",
   LoadingSubtitle = "by Quoc Hoa",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "AppleHubV5",
      FileName = "Config"
   },
   KeySystem = false -- Tắt key cho bạn tiện dùng
})

-- Tạo Tab Farming
local FarmingTab = Window:CreateTab("Tab Farming", 4483362458)

FarmingTab:CreateSection("Setting Farm")

FarmingTab:CreateDropdown({
   Name = "Select Weapon:",
   Options = {"Melee","Sword","Blox Fruit"},
   CurrentOption = {"Melee"},
   Callback = function(Option)
      _G.SelectWeapon = Option[1]
   end,
})

FarmingTab:CreateToggle({
   Name = "Select Fast Delay: Fast Attack",
   CurrentValue = true,
   Callback = function(Value)
      _G.FastAttack = Value
   end,
})

FarmingTab:CreateSection("Main")

FarmingTab:CreateToggle({
   Name = "Auto Farm Level",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoFarm = Value
   end,
})

