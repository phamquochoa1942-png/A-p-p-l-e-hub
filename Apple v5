-- Kiểm tra đã có nhiệm vụ chưa
function HasQuest()
    local success, result = pcall(function()
        -- Kiểm tra qua Remote
        local args = { "GetQuest" }
        local questData = game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer(unpack(args))
        if questData and questData ~= "" and questData ~= "none" and questData ~= nil then
            return true
        end
        
        -- Kiểm tra qua GUI
        local playerGui = game.Players.LocalPlayer.PlayerGui
        if playerGui:FindFirstChild("Quest") then
            local questFrame = playerGui.Quest:FindFirstChild("Frame")
            if questFrame and questFrame.Visible then
                return true
            end
        end
        return false
    end)
    return success and result or false
end

-- Tìm NPC trong Workspace
function FindNPC(npcName)
    for _, v in pairs(game:GetService("Workspace"):GetDescendants()) do
        if v:IsA("Model") and v.Name:lower() == npcName:lower() then
            return v
        end
    end
    for _, v in pairs(game:GetService("Workspace"):GetDescendants()) do
        if v:IsA("Model") and v.Name:lower():find(npcName:lower()) then
            return v
        end
    end
    return nil
end

-- Di chuyển đến NPC và nhận nhiệm vụ
function AcceptQuest(npcName)
    pcall(function()
        local npc = FindNPC(npcName)
        if npc then
            local npcPart = npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChild("Head") or npc:FindFirstChild("Torso")
            if npcPart then
                -- Di chuyển đến NPC
                local char = game.Players.LocalPlayer.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    char.HumanoidRootPart.CFrame = npcPart.CFrame * CFrame.new(0, 0, 3)
                    task.wait(0.8)
                end
                
                -- Gửi lệnh nhận nhiệm vụ
                local args = { "StartQuest", npcName }
                game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer(unpack(args))
                task.wait(0.8)
                return true
            end
        end
        return false
    end)
end

-- Nộp nhiệm vụ
function FinishQuest()
    pcall(function()
        local args = { "FinishQuest" }
        game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer(unpack(args))
        task.wait(0.8)
    end)
end

-- Kiểm tra tiến độ nhiệm vụ
function CheckQuestProgress()
    local success, result = pcall(function()
        -- Lấy thông tin quest từ Remote
        local args = { "GetQuest" }
        local questData = game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer(unpack(args))
        
        if questData and type(questData) == "table" then
            local current = questData[1] or 0
            local required = questData[2] or 0
            return current >= required
        end
        
        -- Kiểm tra qua GUI
        local playerGui = game.Players.LocalPlayer.PlayerGui
        local questGui = playerGui:FindFirstChild("Quest")
        if questGui then
            local frame = questGui:FindFirstChild("Frame")
            if frame then
                for _, v in pairs(frame:GetDescendants()) do
                    if v:IsA("TextLabel") and v.Text then
                        local current, total = v.Text:match("(%d+)/(%d+)")
                        if current and total then
                            return tonumber(current) >= tonumber(total)
                        end
                    end
                end
            end
        end
        return false
    end)
    return success and result or false
end

