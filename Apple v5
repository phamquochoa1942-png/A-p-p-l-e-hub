-- Vòng lặp Auto Quest
spawn(function()
    while true do
        task.wait(2)
        
        if _G.AutoFarm and _G.AutoQuest and not _G.IsDoingQuest then
            pcall(function()
                local currentLevel = GetPlayerLevel()
                local targetNPC = GetNPCByLevel(currentLevel)
                
