_G.AutoFarm = true -- Bật/Tắt farm

task.spawn(function()
    while _G.AutoFarm do
        task.wait(0.1) -- Tốc độ sếp tự chỉnh (0.1 là khá nhanh rồi)

        -- 1. Sếp phải tự cầm vũ khí (vì game check đòn đánh tay)
        local plr = game.Players.LocalPlayer
        local char = plr.Character
        if char then
            local tool = char:FindFirstChildOfClass("Tool") or plr.Backpack:FindFirstChildOfClass("Tool")
            local hum = char:FindFirstChildOfClass("Humanoid")
            if tool and hum and not char:FindFirstChild(tool.Name) then
                hum:EquipTool(tool)
            end
        end

        -- 2. Dùng đúng dòng Remote sếp vừa đưa
        -- Game này sếp soi Spy thấy rỗng nên cứ bắn thẳng thôi
        game:GetService("ReplicatedStorage").CombatSystem.Remotes.RequestHit:FireServer()
    end
end)
