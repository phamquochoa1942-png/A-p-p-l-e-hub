-- ========== LOGIC GOM QUÁI ==========
task.spawn(function()
    while true do
        task.wait()
        if (_G.AutoFarm or _G.AutoMaterial) and _G.BringMob then
            pcall(function()
                local player = game.Players.LocalPlayer
                local character = player.Character
                if not character then return end
                
                local MyPos = character.HumanoidRootPart.Position
                local TargetPos = MyPos + Vector3.new(0, -5, 0)
                
                for _, v in pairs(game:GetService("Workspace").Enemies:GetChildren()) do
                    if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v:FindFirstChild("HumanoidRootPart") then
                        local distance = (v.HumanoidRootPart.Position - MyPos).Magnitude
                        if distance <= _G.DistanceMob then
                            v.HumanoidRootPart.CanCollide = false
                            v.HumanoidRootPart.CFrame = CFrame.new(TargetPos)
                            if v.Humanoid:FindFirstChild("Animator") then
                                v.Humanoid.Animator:Destroy()
                            end
                        end
                    end
                end
                
                game:GetService("VirtualUser"):CaptureController()
                game:GetService("VirtualUser"):ClickButton1(Vector2.new(50, 50))
            end)
        end
    end
end)

-- ========== LOGIC AUTO QUEST ==========
task.spawn(function()
    while true do
        task.wait(2)
        if _G.AutoQuest and (_G.AutoFarm or _G.AutoMaterial) then
            pcall(function()
                local player = game.Players.LocalPlayer
                local character = player.Character
                if not character then return end
                
                local hasQuest = player:FindFirstChild("Quest") ~= nil
                
                if not hasQuest then
                    local MyPos = character.HumanoidRootPart.Position
                    local questNPC = nil
                    
                    for _, v in pairs(game.Workspace:GetChildren()) do
                        if v.Name == _G.QuestNPC or v.Name == "Quest Giver" then
                            if v:FindFirstChild("HumanoidRootPart") then
                                questNPC = v
                                break
                            end
                        end
                    end
                    
                    if questNPC and questNPC.HumanoidRootPart then
                        local distance = (questNPC.HumanoidRootPart.Position - MyPos).Magnitude
                        if distance <= 50 then
                            local remote = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes")
                            if remote then
                                local questRemote = remote:FindFirstChild("Quest")
                                if questRemote then
                                    questRemote:FireServer(questNPC)
                                    task.wait(0.5)
                                end
                            end
                        else
                            character.HumanoidRootPart.CFrame = CFrame.new(questNPC.HumanoidRootPart.Position + Vector3.new(0, 0, 5))
                            task.wait(1)
                        end
                    end
                else
                    local questData = player:FindFirstChild("Quest")
                    if questData then
                        local required = questData:FindFirstChild("Required") or questData:FindFirstChild("Needed")
                        local current = questData:FindFirstChild("Current") or questData:FindFirstChild("Progress")
                        
                        if required and current and current.Value >= required.Value then
                            local questNPC = nil
                            for _, v in pairs(game.Workspace:GetChildren()) do
                                if v.Name == _G.QuestNPC or v.Name == "Quest Giver" then
                                    if v:FindFirstChild("HumanoidRootPart") then
                                        questNPC = v
                                        break
                                    end
                                end
                            end
                            
                            if questNPC then
                                character.HumanoidRootPart.CFrame = CFrame.new(questNPC.HumanoidRootPart.Position + Vector3.new(0, 0, 5))
                                task.wait(1)
                                
                                local remote = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes")
                                if remote then
                                    local questRemote = remote:FindFirstChild("Quest")
                                    if questRemote then
                                        questRemote:FireServer(questNPC)
                                        task.wait(0.5)
                                    end
                                end
                            end
                        end
                    end
                end
            end)
        end
    end
end)

