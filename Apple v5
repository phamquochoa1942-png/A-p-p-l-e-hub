-- Kiểm tra đã có nhiệm vụ chưa
function HasQuest()
    local success, result = pcall(function()
        local args = { "GetQuest" }
        local questData = game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer(unpack(args))
        
        if questData and questData ~= nil and questData ~= "" and questData ~= "none" then
            if type(questData) == "table" and #questData > 0 then
                return true
            end
            if type(questData) == "string" and questData ~= "" and questData ~= "0" then
                return true
            end
        end
        return false
    end)
    return success and result or false
end

-- Tìm NPC trong Workspace
function FindNPC(npcNames)
    for _, name in ipairs(npcNames) do
        for _, v in pairs(game:GetService("Workspace"):GetDescendants()) do
            if v:IsA("Model") and v.Name == name then
                return v
            end
        end
    end
    
    for _, name in ipairs(npcNames) do
        for _, v in pairs(game:GetService("Workspace"):GetDescendants()) do
            if v:IsA("Model") and v.Name:lower():find(name:lower()) then
                return v
            end
        end
    end
    
    for _, v in pairs(game:GetService("Workspace"):GetDescendants()) do
        if v:IsA("Model") and v.Name:lower():find("quest") then
            return v
        end
    end
    
    return nil
end

-- Nhận nhiệm vụ
function AcceptQuest(npcNames)
    pcall(function()
        local npc = FindNPC(npcNames)
        if npc then
            local npcPart = npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChild("Head") or npc:FindFirstChild("Torso")
            if npcPart then
                _G.IsDoingQuest = true
                
                local wasFarming = _G.AutoFarm
                _G.AutoFarm = false
                
                local char = game.Players.LocalPlayer.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    char.HumanoidRootPart.CFrame = npcPart.CFrame * CFrame.new(0, 0, 3)
                    task.wait(1)
                end
                
                for _, name in ipairs(npcNames) do
                    local args = { "StartQuest", name }
                    game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer(unpack(args))
                    task.wait(0.5)
                    
                    if HasQuest() then
                        break
                    end
                end
                
                _G.AutoFarm = wasFarming
                _G.IsDoingQuest = false
                return true
            end
        end
        _G.IsDoingQuest = false
        return false
    end)
end

-- Nộp nhiệm vụ
function FinishQuest()
    pcall(function()
        _G.IsDoingQuest = true
        
        local wasFarming = _G.AutoFarm
        _G.AutoFarm = false
        
        local args = { "FinishQuest" }
        game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer(unpack(args))
        task.wait(1)
        
        _G.AutoFarm = wasFarming
        _G.IsDoingQuest = false
    end)
end

-- Kiểm tra tiến độ nhiệm vụ
function CheckQuestProgress()
    local success, result = pcall(function()
        local args = { "GetQuest" }
        local questData = game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer(unpack(args))
        
        if type(questData) == "table" and #questData >= 2 then
            local current = tonumber(questData[1]) or 0
            local required = tonumber(questData[2]) or 0
            return current >= required
        end
        return false
    end)
    return success and result or false
end

