-- FindNPC: ĐÃ FIX - tìm NPC theo tên, kể cả khi tên bị add hậu tố (level, ID, etc.)
function FindNPC(npcName)
    npcName = npcName:lower()
    local allNPCs = {}

    -- Duyệt vật thể trong Workspace
    for _, model in ipairs(workspace:GetChildren()) do
        if model:IsA("Model") and model:FindFirstChildWhichIsA("Humanoid") and model:FindFirstChild("HumanoidRootPart") then
            local name = model.Name:lower()
            if name == npcName then return model end -- exact match
            if name:find(npcName) then table.insert(allNPCs, model) end -- partial match
        end
    end
    
    -- Duyệt sâu hơn
    if #allNPCs == 0 then
        for _, desc in ipairs(workspace:GetDescendants()) do
            if desc:IsA("Model") and desc:FindFirstChild("Humanoid") and desc:FindFirstChild("HumanoidRootPart") then
                local name = desc.Name:lower()
                if name:match(npcName:gsub("%W", "%%")) then
                    table.insert(allNPCs, desc)
                end
            end
        end
    end

    -- Chọn NPC gần nhất
    if #allNPCs > 0 then
        local closestNPC = nil
        local closestDist = math.huge
        local playerRoot = game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if playerRoot then
            for _, npc in ipairs(allNPCs) do
                local dist = (npc.HumanoidRootPart.Position - playerRoot.Position).Magnitude
                if dist < closestDist then
                    closestDist = dist
                    closestNPC = npc
                end
            end
        end
        return closestNPC
    end

    return nil
end

-- AcceptQuest: ĐÃ FIX - phải MoveTo, rồi mới InvokeServer
function AcceptQuest(npcName)
    pcall(function()
        local npc = FindNPC(npcName)
        if not npc then 
            print("[AutoQuest] ❌ Không tìm thấy NPC:", npcName)
            return false 
        end
        
        -- Di chuyển đến NPC (đảm bảo script thực hiện đúng thứ tự)
        if game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("Humanoid") then
            local charHRP = game.Players.LocalPlayer.Character.HumanoidRootPart
            local npcHRP = npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChild("Head") or npc:FindFirstChild("Torso")
            if npcHRP then
                local direction = (npcHRP.Position - charHRP.Position).unit
                local targetPos = npcHRP.Position - direction * 5
                
                game.Players.LocalPlayer.Character.Humanoid:MoveTo(targetPos)
                local success = game.Players.LocalPlayer.Character.Humanoid.MoveToFinished:Wait(2)
                
                -- Đợi humanoid dừng lại
                local count = 0
                while game.Players.LocalPlayer.Character.Humanoid.Health > 0 and 
                      game.Players.LocalPlayer.Character.Humanoid.MoveDistance > 0 and count < 10 do
                    task.wait(0.2) count = count + 1
                end
            end
        end
        
        -- Gửi Remote *SAU KHI* đã đi đến vị trí NPC
        local success, err = pcall(function()
            return game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("StartQuest", npcName)
        end)
        
        if not success then
            warn("[AutoQuest] ❌ Lỗi InvokeServer:", err)
        else
            print("[AutoQuest] ✅ Đã gửi yêu cầu nhận nhiệm vụ:", npcName)
        end
        return true
    end)
    return false
end

