-- Vòng lặp Auto Quest
spawn(function()
    while true do
        task.wait(3)
        
        if _G.AutoFarm and _G.AutoQuest and not _G.IsDoingQuest then
            pcall(function()
                local currentLevel = GetPlayerLevel()
                local targetNPCs = GetNPCByLevel(currentLevel)
                
                local hasQuest = HasQuest()
                
                if not hasQuest then
                    AcceptQuest(targetNPCs)
                    task.wait(2)
                else
                    if _G.AutoFinishQuest then
                        local isComplete = CheckQuestProgress()
                        if isComplete then
                            FinishQuest()
                            task.wait(2)
                        end
                    end
                end
            end)
        end
    end
end)

