_G.AutoFarm = true -- Bật/Tắt farm

task.spawn(function()
    while _G.AutoFarm do
        task.wait(0.1) -- Tốc độ đánh
        -- Quét quái trong folder NPCs sếp soi được trong Dex
        for _, v in pairs(workspace.NPCs:GetChildren()) do
            if v:IsA("Model") and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                local root = v:FindFirstChild("HumanoidRootPart")
                if root then
                    -- Remote chuẩn Sailor Piece
                    local args = {
                        [1] = v, -- Target model quái
                        [2] = {
                            ["HitPart"] = v:FindFirstChild("RightUpperLeg") or root,
                            ["HitPos"] = root.Position
                        }
                    }
                    game:GetService("ReplicatedStorage").CombatSystem.Remotes.RequestHit:FireServer(unpack(args))
                end
            end
        end
    end
end)
