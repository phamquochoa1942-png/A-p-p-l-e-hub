    if MainFrame then
        local TopBar = MainFrame:FindFirstChild("Topbar")
        if TopBar then
            local CurrentIcon = TopBar:FindFirstChild("Icon")
            if CurrentIcon then CurrentIcon.ImageTransparency = 1 end -- Ẩn icon vuông cũ

            -- Tạo hình tròn đỏ (như ảnh bạn yêu cầu)
            local RedCircle = Instance.new("Frame")
            local UICorner = Instance.new("UICorner")
            local AppleIcon = Instance.new("ImageLabel")

            RedCircle.Name = "AppleCircle"
            RedCircle.Parent = TopBar
            RedCircle.BackgroundColor3 = Color3.fromRGB(255, 0, 0) -- Màu đỏ rực
            RedCircle.BorderSizePixel = 0
            RedCircle.Position = UDim2.new(0.015, 0, 0.15, 0)
            RedCircle.Size = UDim2.new(0, 32, 0, 32)
            RedCircle.ZIndex = 10

            UICorner.CornerRadius = UDim.new(1, 0) -- Bo tròn 100%
            UICorner.Parent = RedCircle

            AppleIcon.Name = "AppleIcon"
            AppleIcon.Parent = RedCircle
            AppleIcon.AnchorPoint = Vector2.new(0.5, 0.5)
            AppleIcon.Position = UDim2.new(0.5, 0, 0.5, 0)
            AppleIcon.Size = UDim2.new(0.85, 0, 0.85, 0) -- Ảnh Heo Táo nằm trong vòng tròn
            AppleIcon.BackgroundTransparency = 1
            -- ID LOGO HEO TÁO MỞ MẮT 10/10 CỦA BẠN
            AppleIcon.Image = "rbxassetid://1774948265257" 
            AppleIcon.ZIndex = 11
        end
    end
end)

