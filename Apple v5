_G.AutoFarm = true -- Bật/Tắt farm

task.spawn(function()
    while _G.AutoFarm do
        task.wait(0.1)

        -- 1. Tự cầm vũ khí
        local plr = game.Players.LocalPlayer
        local char = plr.Character
        if char then
            local tool = char:FindFirstChildOfClass("Tool") or plr.Backpack:FindFirstChildOfClass("Tool")
            local hum = char:FindFirstChildOfClass("Humanoid")
            if tool and hum and not char:FindFirstChild(tool.Name) then
                hum:EquipTool(tool)
            end
        end

        -- 2. Hitbox (Sửa lỗi dính chữ và sai chính tả của sếp nè)
        for i, v in pairs(game:GetService("Workspace").NPCs:GetChildren()) do
            if v:FindFirstChild("HumanoidRootPart") then -- Sếp nhớ gõ liền chữ này nha
                v.HumanoidRootPart.Size = Vector3.new(35, 35, 35)
                v.HumanoidRootPart.Transparency = 0.5 -- Sửa từ Transpace thành Transparency
                v.HumanoidRootPart.CanCollide = false
            end
        end

        -- 3. Đánh quái
        game:GetService("ReplicatedStorage").CombatSystem.Remotes.RequestHit:FireServer()
    end
end)
