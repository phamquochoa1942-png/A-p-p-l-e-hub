    end)
end

-- ✅ Kiểm tra nhiệm vụ có tồn tại hay không
function HasQuest()
    local success, questData = pcall(function()
        return game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("GetQuest")
    end)
    if success and questData and questData ~= "none" and questData ~= "" and questData ~= nil then
        return true
    end

    local player = game.Players.LocalPlayer
    local playerGui = player:FindFirstChild("PlayerGui")
    if playerGui then
        for _, gui in ipairs(playerGui:GetChildren()) do
            if gui:IsA("ScreenGui") and (gui.Name == "Quest" or gui.Name:lower():find("quest")) then
                for _, frame in ipairs(gui:GetDescendants()) do
                    if frame:IsA("Frame") and frame.Visible then
                        for _, lbl in ipairs(frame:GetDescendants()) do
                            if lbl:IsA("TextLabel") then
                                local txt = lbl.Text:lower()
                                if txt:find("quest") or txt:find("nhiệm vụ") or txt:find("已完成") then
                                    return true
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    return false
end

-- ✅ Kiểm tra tiến độ nhiệm vụ
function CheckQuestProgress()
    local success, questData = pcall(function()
        return game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("GetQuest")
    end)
    
    if success and questData and type(questData) == "table" then
        local current = questData[1] or 0
        local required = questData[2] or 0
        return current >= required
    end

    local player = game.Players.LocalPlayer
    local playerGui = player:FindFirstChild("PlayerGui")
    if playerGui then
        for _, gui in ipairs(playerGui:GetChildren()) do
            if gui:IsA("ScreenGui") and gui.Name:lower():find("quest") then
                for _, frame in ipairs(gui:GetDescendants()) do
                    if frame:IsA("Frame") then
                        for _, lbl in ipairs(frame:GetDescendants()) do
                            if lbl:IsA("TextLabel") and lbl.Text and type(lbl.Text) == "string" then
                                local current, total = lbl.Text:match("(%d+)/(%d+)")
                                if current and total then
                                    return tonumber(current) >= tonumber(total)
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    return false
end


