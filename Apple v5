-- Bật Haki
function EnableHaki()
    pcall(function()
        if _G.AutoHaki then
            game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("Bus", true)
            wait(0.2)
            game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("Buso", true)
        end
    end)
end

-- Gom quái về chân
function BringMob()
    pcall(function()
        local char = game.Players.LocalPlayer.Character
        if not char then return end
        local myPos = char.HumanoidRootPart.Position
        local targetPos = myPos + Vector3.new(0, -5, 0)
        
        for _, v in pairs(workspace.Enemies:GetChildren()) do
            if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                if v:FindFirstChild("HumanoidRootPart") then
                    local dist = (v.HumanoidRootPart.Position - myPos).Magnitude
                    if dist <= 300 then
                        v.HumanoidRootPart.CFrame = CFrame.new(targetPos)
                        v.HumanoidRootPart.Velocity = Vector3.new(0,0,0)
                    end
                end
            end
        end
    end)
end

-- Bay lên quái
function FlyToMob()
    pcall(function()
        local char = game.Players.LocalPlayer.Character
        if not char then return end
        
        local nearest = nil
        local nearestDist = 500
        
        for _, v in pairs(workspace.Enemies:GetChildren()) do
            if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                if v:FindFirstChild("HumanoidRootPart") then
                    local dist = (v.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude
                    if dist < nearestDist then
                        nearestDist = dist
                        nearest = v
                    end
                end
            end
        end
        
        if nearest and nearest.HumanoidRootPart then
            local pos = nearest.HumanoidRootPart.Position
            char.HumanoidRootPart.CFrame = CFrame.new(pos.X, pos.Y + 15, pos.Z)
        end
    end)
end

