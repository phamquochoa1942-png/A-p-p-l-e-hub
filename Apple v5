-- Hàm bay lên trên quái
function FlyAboveMob()
    pcall(function()
        if _G.IsDoingQuest then return end
        
        local player = game.Players.LocalPlayer
        local char = player.Character
        if not char then return end
        if not char:FindFirstChild("HumanoidRootPart") then return end
        
        local nearestMob = nil
        local nearestDist = 400
        
        for _, v in pairs(game:GetService("Workspace").Enemies:GetChildren()) do
            if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v:FindFirstChild("HumanoidRootPart") then
                local dist = (v.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude
                if dist < nearestDist then
                    nearestDist = dist
                    nearestMob = v
                end
            end
        end
        
        if nearestMob and nearestMob:FindFirstChild("HumanoidRootPart") then
            local mobPos = nearestMob.HumanoidRootPart.Position
            local flyPos = mobPos + Vector3.new(0, 15, 0)
            char.HumanoidRootPart.CFrame = CFrame.new(flyPos)
        end
    end)
end

-- Hàm tự động đánh quái
function AutoAttack()
    pcall(function()
        if _G.IsDoingQuest then return end
        
        local VirtualUser = game:GetService("VirtualUser")
        VirtualUser:CaptureController()
        VirtualUser:ClickButton1(Vector2.new(50, 50))
    end)
end

-- Hàm gom quái
function BringMobFunction()
    pcall(function()
        if _G.IsDoingQuest then return end
        
        local player = game.Players.LocalPlayer
        local char = player.Character
        if not char then return end
        if not char:FindFirstChild("HumanoidRootPart") then return end
        
        local MyPos = char.HumanoidRootPart.Position
        local TargetPos = MyPos + Vector3.new(0, -5, 0)
        
        for _, v in pairs(game:GetService("Workspace").Enemies:GetChildren()) do
            if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v:FindFirstChild("HumanoidRootPart") then
                local distance = (v.HumanoidRootPart.Position - MyPos).Magnitude
                if distance <= 350 then
                    pcall(function()
                        v.HumanoidRootPart.CanCollide = false
                        v.HumanoidRootPart.CFrame = CFrame.new(TargetPos)
                        v.HumanoidRootPart.Velocity = Vector3.new(0,0,0)
                        if v.Humanoid:FindFirstChild("Animator") then
                            v.Humanoid.Animator:Destroy()
                        end
                        v.Humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
                        v.Humanoid.JumpPower = 0
                        v.Humanoid.WalkSpeed = 0
                    end)
                end
            end
        end
    end)
end

