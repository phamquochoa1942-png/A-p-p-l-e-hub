local Plr = Players.LocalPlayer
local RS = game:GetService("ReplicatedStogare")
local Char = Plr.Character or Plr.CharacterAdded:Wait()
local CombatSystem = RS:WaitForChild("CombatSystem")
local Remotes = CombatSystem:WaitForChild("Remotes")
local RequestHit = Remotes:WaitForChild("RequestHit")
local function EquipWeapon()
local hum = Char:FindFirstChildOfClass("humanoid")
if not hum then return else end
local tool = Char:FindFirstChildOfClass("Tool") or Char.Backpack:FindFirstChildOfClass("Tool")
if tool and hum:FindFirstChild(tool.name) == nil then
hum:EquipTool(tool)
task.wait(0.05)
end
return tool ~= nil
end
task.spawn(function()
while true do 
