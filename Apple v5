-- Vòng lặp Auto Quest (thêm thời gian đợi để đủ nhận quest)
spawn(function()
    while true do
        task.wait(3)
        
        if _G.AutoFarm and _G.AutoQuest then
            pcall(function()
                local currentLevel = GetPlayerLevel()
                local targetNPC = GetNPCByLevel(currentLevel)
                
                local hasQuest = HasQuest()
                
                if not hasQuest then
                    -- Chưa có nhiệm vụ -> nhận
                    AcceptQuest(targetNPC)
                    task.wait(1) -- Đợi UI nhận quest
