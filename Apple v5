-- Hàm tự động đánh quái
function AutoAttack()
    pcall(function()
        -- Click chuột trái liên tục
        game:GetService("VirtualUser"):CaptureController()
        game:GetService("VirtualUser"):ClickButton1(Vector2.new(50, 50))
        
        -- Sử dụng kỹ năng nếu có
        if _G.FastAttack then
            local player = game.Players.LocalPlayer
            local char = player.Character
            if char then
                -- Sử dụng các phím kỹ năng
                local VirtualInputManager = game:GetService("VirtualInputManager")
                if _G.SelectWeapon == "Melee" then
                    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Z, false, game)
                    task.wait(0.05)
                    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Z, false, game)
                    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.X, false, game)
                    task.wait(0.05)
                    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.X, false, game)
                elseif _G.SelectWeapon == "Sword" then
                    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Z, false, game)
                    task.wait(0.05)
                    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Z, false, game)
                elseif _G.SelectWeapon == "Blox Fruit" then
                    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Z, false, game)
                    task.wait(0.05)
                    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Z, false, game)
                    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.X, false, game)
                    task.wait(0.05)
                    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.X, false, game)
                    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.C, false, game)
                    task.wait(0.05)
                    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.C, false, game)
                end
            end
        end
    end)
end

-- Hàm gom quái (kéo quái về vị trí)
function BringMobFunction()
    pcall(function()
        if not _G.BringMob then return end
        local player = game.Players.LocalPlayer
        local char = player.Character
        if not char then return end
        
        local MyPos = char.HumanoidRootPart.Position
        local TargetPos = MyPos + Vector3.new(0, -5, 0)
        
        for _, v in pairs(game:GetService("Workspace").Enemies:GetChildren()) do
            if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v:FindFirstChild("HumanoidRootPart") then
                local distance = (v.HumanoidRootPart.Position - MyPos).Magnitude
                if distance <= _G.DistanceMob then
                    pcall(function()
                        v.HumanoidRootPart.CanCollide = false
                        v.HumanoidRootPart.CFrame = CFrame.new(TargetPos)
                        v.HumanoidRootPart.Velocity = Vector3.new(0,0,0)
                        -- Tắt AI của quái
                        if v.Humanoid:FindFirstChild("Animator") then
                            v.Humanoid.Animator:Destroy()
                        end
                    end)
                end
            end
        end
    end)
end

