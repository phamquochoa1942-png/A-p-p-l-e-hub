local FPSGroup = FixLagTab:AddRightGroupbox("📊 Hiển Thị FPS")
local fpsEnabled = false
FPSGroup:AddToggle("FPSDisplay", {
    Title = "Hiện FPS trên màn hình",
    Default = false,
    Callback = function(value)
        fpsEnabled = value
        if fpsEnabled then
            local gui = Instance.new("ScreenGui")
            gui.Name = "FPS_Display"
            gui.Parent = game:GetService("CoreGui")
            local label = Instance.new("TextLabel")
            label.Parent = gui
            label.BackgroundTransparency = 1
            label.Position = UDim2.new(0.01, 0, 0.01, 0)
            label.Size = UDim2.new(0, 80, 0, 30)
            label.Font = Enum.Font.GothamBold
            label.TextColor3 = Color3.fromRGB(255, 255, 255)
            label.TextSize = 16
            label.Text = "FPS: 0"
            local frames = 0
            local lastTime = tick()
            game:GetService("RunService").RenderStepped:Connect(function()
                if fpsEnabled then
                    frames = frames + 1
                    if tick() - lastTime >= 1 then
                        label.Text = "FPS: " .. frames
                        frames = 0
                        lastTime = tick()
                    end
                end
            end)
        else
            local gui = game:GetService("CoreGui"):FindFirstChild("FPS_Display")
            if gui then gui:Destroy() end
        end
    end
})

