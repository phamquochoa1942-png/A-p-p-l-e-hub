-- Kiểm tra có quest chưa
function HasQuest()
    pcall(function()
        local data = game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("GetQuest")
        if data and data ~= "" and data ~= "none" then
            if type(data) == "table" and #data > 0 then
                return true
            end
            if type(data) == "string" and data ~= "" then
                return true
            end
        end
    end)
    return false
end

-- Kiểm tra quest hoàn thành chưa
function IsQuestComplete()
    pcall(function()
        local data = game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("GetQuest")
        if type(data) == "table" and #data >= 2 then
            local current = tonumber(data[1]) or 0
            local required = tonumber(data[2]) or 0
            return current >= required
        end
    end)
    return false
end

-- Tìm NPC
function FindQuestNPC(npcName)
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Model") and v.Name == npcName then
            return v
        end
    end
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Model") and v.Name:lower():find("quest") then
            return v
        end
    end
    return nil
end

-- Di chuyển đến NPC
function MoveToNPC(npc)
    if npc then
        local part = npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChild("Head")
        if part then
            game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = part.CFrame * CFrame.new(0, 0, 3)
            wait(1)
        end
    end
end

-- Nhận quest
function AcceptQuest(npcName)
    pcall(function()
        local npc = FindQuestNPC(npcName)
        if npc then
            MoveToNPC(npc)
            game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("StartQuest", npcName)
            wait(1)
        end
    end)
end

-- Nộp quest
function FinishQuest()
    pcall(function()
        game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("FinishQuest")
        wait(1)
    end)
end

-- ==================== VÒNG LẶP CHÍNH ====================

-- Vòng lặp Farm
spawn(function()
    while true do
        wait(0.1)
        
        if _G.AutoFarm then
            pcall(function()
                -- Gom quái
                BringMob()
                -- Bay lên quái
                FlyToMob()
                -- Đánh
                Attack()
                -- Bật Haki
                EnableHaki()
            end)
        end
    end
end)

-- Vòng lặp Quest
spawn(function()
    while true do
        wait(2)
        
        if _G.AutoFarm and _G.AutoQuest then
            pcall(function()
                local level = GetLevel()
                local npcName = GetQuestNPC(level)
                
                if not HasQuest() then
                    -- Chưa có quest -> nhận
                    AcceptQuest(npcName)
                else
                    -- Có quest -> kiểm tra hoàn thành
                    if _G.AutoFinishQuest and IsQuestComplete() then
                        FinishQuest()
                    end
                end
            end)
        end
    end
end)

