_G.AutoQuestEnabled = true

task.spawn(function()
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local Players = game:GetService("Players")
    local TweenService = game:GetService("TweenService")
    local VirtualInputManager = game:GetService("VirtualInputManager")
    local RunService = game:GetService("RunService")
    local LocalPlayer = Players.LocalPlayer
    local AttackRemote = ReplicatedStorage.CombatSystem.Remotes.RequestHit
    
    local OriginalGravity = workspace.Gravity
    local NoFallConnection = nil
    local IsClicking = false
    
    local QuestRoute = {
        {MinLv = 1, MaxLv = 99, Mob = "Thief", QuestName = "Thief Hunter"},
        {MinLv = 100, MaxLv = 249, Mob = "Thief Boss", QuestName = "Thief Boss"},
        {MinLv = 250, MaxLv = 499, Mob = "Monkey", QuestName = "Monkey Hunter"},
        {MinLv = 500, MaxLv = 749, Mob = "Monkey Boss", QuestName = "Monkey Boss"},
        {MinLv = 750, MaxLv = 999, Mob = "Desert Bandit", QuestName = "Desert Bandit"},
        {MinLv = 1000, MaxLv = 1499, Mob = "Desert Bandit Boss", QuestName = "Desert Boss"},
        {MinLv = 1500, MaxLv = 1999, Mob = "Frost Rogue", QuestName = "Frost Rogue"},
        {MinLv = 2000, MaxLv = 2999, Mob = "Winter Warden Boss", QuestName = "Winter Warden"},
        {MinLv = 3000, MaxLv = 3999, Mob = "Sorcerer", QuestName = "Sorcerer Hunter"},
        {MinLv = 4000, MaxLv = 5000, Mob = "Panda Sorcerer", QuestName = "Panda Boss"},
        {MinLv = 5000, MaxLv = 6250, Mob = "Hollow", QuestName = "Hollow Hunter"},
        {MinLv = 6250, MaxLv = 7000, Mob = "Strong Sorcerer", QuestName = "Strong Sorcerer Hunter"},
        {MinLv = 7000, MaxLv = 8000, Mob = "Curse", QuestName = "Curse Hunter"},
        {MinLv = 8000, MaxLv = 9000, Mob = "Slime Warrior", QuestName = "Slime Warrior"},
        {MinLv = 9000, MaxLv = 10000, Mob = "Academy Teacher", QuestName = "Academy Challenge"},
        {MinLv = 10000, MaxLv = 11500, Mob = "Quincy", QuestName = "Quincy Hunter"},
        {MinLv = 11500, MaxLv = 12000, Mob = "Ninja", QuestName = "Ninja"},
        {MinLv = 12000, MaxLv = 16000, Mob = "Arena Fighter", QuestName = "Arena Fighter"}
    }
    
    local function GetLevel()
        local LevelValue = nil
        
        if LocalPlayer:FindFirstChild("Data") then
            LevelValue = LocalPlayer.Data:FindFirstChild("Level")
        end
        
        if not LevelValue then
            LevelValue = LocalPlayer:FindFirstChild("Level")
        end
        
        if not LevelValue then
            local Leaderstats = LocalPlayer:FindFirstChild("leaderstats")
            if Leaderstats then
                LevelValue = Leaderstats:FindFirstChild("Level") or Leaderstats:FindFirstChild("LVL")
            end
        end
        
        if not LevelValue then
            warn("Khong tim thay data Level")
            return nil
        end
        
        return LevelValue.Value or 1
    end
    
    local function GetCurrentQuestConfig()
        local Lv = GetLevel()
        if not Lv then return nil end
        
        for _, cfg in ipairs(QuestRoute) do
            if Lv >= cfg.MinLv and Lv <= cfg.MaxLv then
                return cfg
            end
        end
        return QuestRoute[#QuestRoute]
    end
    
    local function FindNPC(questName)
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("Model") and string.find(obj.Name, questName) and obj:FindFirstChild("Head") then
                return obj
            end
        end
        return nil
    end
    
    local function HasQuest(questName)
        local PlayerGui = LocalPlayer.PlayerGui
        for _, gui in ipairs(PlayerGui:GetChildren()) do
            for _, child in ipairs(gui:GetDescendants()) do
                if child:IsA("TextLabel") and string.find(child.Text, questName) then
                    return true
                end
            end
        end
        return false
    end
    
    local function StopNoFall()
        if NoFallConnection then
            NoFallConnection:Disconnect()
            NoFallConnection = nil
        end
        workspace.Gravity = OriginalGravity
        local Char = LocalPlayer.Character
        if Char then
            local Humanoid = Char:FindFirstChildOfClass("Humanoid")
            if Humanoid then
                Humanoid.WalkSpeed = 16
                Humanoid.JumpPower = 50
                Humanoid.PlatformStand = false
                Humanoid.AutoRotate = true
            end
            for _, Part in ipairs(Char:GetDescendants()) do
                if Part:IsA("BasePart") then
                    Part.CanCollide = true
                end
            end
        end
    end
    
    local function StartNoFall()
        StopNoFall()
        workspace.Gravity = 0
        local Char = LocalPlayer.Character
        if Char then
            local Humanoid = Char:FindFirstChildOfClass("Humanoid")
            if Humanoid then
                Humanoid.WalkSpeed = 0
                Humanoid.JumpPower = 0
                Humanoid.PlatformStand = true
            end
            for _, Part in ipairs(Char:GetDescendants()) do
                if Part:IsA("BasePart") and Part.Name ~= "HumanoidRootPart" then
                    Part.CanCollide = false
                end
            end
        end
        NoFallConnection = RunService.Heartbeat:Connect(function()
            local Char = LocalPlayer.Character
            if Char then
                local Root = Char:FindFirstChild("HumanoidRootPart")
                if Root then
                    Root.Velocity = Vector3.new(0, 0, 0)
                    Root.RotVelocity = Vector3.new(0, 0, 0)
                end
            end
        end)
    end
    
    local function AcceptQuest(cfg)
        if not cfg then return false end
        if HasQuest(cfg.QuestName) then return true end
        
        local NPC = FindNPC(cfg.QuestName)
        if not NPC then return false end
        
        local Char = LocalPlayer.Character
        if not Char then return false end
        
        local Root = Char:FindFirstChild("HumanoidRootPart")
        if not Root then return false end
        
        local NPCRoot = NPC:FindFirstChild("HumanoidRootPart") or NPC:FindFirstChild("Head")
        if not NPCRoot then return false end
        
        local Distance = (Root.Position - NPCRoot.Position).Magnitude
        if Distance > 100 then
            TweenService:Create(Root, TweenInfo.new(Distance / 100, Enum.EasingStyle.Linear), {CFrame = NPCRoot.CFrame * CFrame.new(0, 0, -5)}):Play()
            task.wait(Distance / 100)
        else
            Root.CFrame = NPCRoot.CFrame * CFrame.new(0, 0, -5)
        end
        
        local Prompt = NPC:FindFirstChildWhichIsA("ProximityPrompt")
        if Prompt then
            fireproximityprompt(Prompt)
            task.wait(1)
        end
        
        local PlayerGui = LocalPlayer.PlayerGui
        for _, gui in ipairs(PlayerGui:GetChildren()) do
            for _, btn in ipairs(gui:GetDescendants()) do
                if btn:IsA("TextButton") and (string.find(btn.Text, "Accept") or string.find(btn.Text, "Yes")) then
                    local ClickDetector = btn:FindFirstChildWhichIsA("ClickDetector")
                    if ClickDetector then
                        fireclickdetector(ClickDetector)
                    end
                    break
                end
            end
        end
        
        task.wait(1)
        return HasQuest(cfg.QuestName)
    end
    
    local function FindEnemy(mobName)
        local NPCs = workspace:FindFirstChild("NPCs")
        if not NPCs then return nil end
        
        for _, obj in ipairs(NPCs:GetChildren()) do
            if obj:IsA("Model") and obj.Name == mobName then
                local Humanoid = obj:FindFirstChildOfClass("Humanoid")
                local Root = obj:FindFirstChild("HumanoidRootPart")
                if Humanoid and Humanoid.Health > 0 and Root then
                    return obj
                end
            end
        end
        return nil
    end
    
    local function ForceReset()
        IsClicking = false
        StopNoFall()
    end
    
    task.spawn(function()
        while _G.AutoQuestEnabled do
            if IsClicking then
                VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
                task.wait()
                VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
                task.wait()
            else
                task.wait(0.05)
            end
        end
    end)
    
    while _G.AutoQuestEnabled do
        local Character = LocalPlayer.Character
        if not Character then
            ForceReset()
            task.wait(1)
            continue
        end
        
        local Root = Character:FindFirstChild("HumanoidRootPart")
        if not Root then
            ForceReset()
            task.wait(1)
            continue
        end
        
        local Humanoid = Character:FindFirstChildOfClass("Humanoid")
        if not Humanoid or Humanoid.Health <= 0 then
            ForceReset()
            task.wait(1)
            continue
        end
        
        local cfg = GetCurrentQuestConfig()
        if not cfg then
            task.wait(1)
            continue
        end
        
        AcceptQuest(cfg)
        
        local Target = FindEnemy(cfg.Mob)
        if Target then
            IsClicking = true
            StartNoFall()
            
            local EnemyRoot = Target:FindFirstChild("HumanoidRootPart")
            if EnemyRoot then
                local Distance = (Root.Position - EnemyRoot.Position).Magnitude
                if Distance > 50 then
                    TweenService:Create(Root, TweenInfo.new(Distance / 100, Enum.EasingStyle.Linear), {CFrame = EnemyRoot.CFrame * CFrame.new(0, 10, 0)}):Play()
                    task.wait(Distance / 100)
                end
            end
            
            while _G.AutoQuestEnabled and Target and Target.Parent and Target:FindFirstChildOfClass("Humanoid") and Target.Humanoid.Health > 0 do
                EnemyRoot = Target:FindFirstChild("HumanoidRootPart")
                if not EnemyRoot then break end
                
                Root.CFrame = EnemyRoot.CFrame * CFrame.new(0, 10, 0)
                Root.Velocity = Vector3.new(0, 0, 0)
                
                pcall(function()
                    AttackRemote:FireServer()
                end)
                
                task.wait()
            end
            
            ForceReset()
        else
            ForceReset()
            task.wait(2)
        end
    end
end)
