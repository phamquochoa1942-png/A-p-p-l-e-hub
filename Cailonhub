task.spawn(function()
    while _G.AutoQuestEnabled do
        if _G.FastAttackEnabled and isFloating then
            local data = getBestFarmData(getLevel())
            if data then
                local targets = getNearbyTargets(data.mobs)
                for _, target in ipairs(targets) do
                    local targetPart = GetTargetPart(target)
                    if targetPart then
                        pcall(function()
                            RequestHit:FireServer(targetPart)
                        end)
                    end
                end
            end
        end
        task.wait()
    end
end)

task.spawn(function()
    repeat task.wait() until LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    
    while _G.AutoQuestEnabled do
        task.wait(1)
        
        local level = getLevel()
        local data = getBestFarmData(level)
        if not data then continue end
        
        if currentQuest ~= data.quest then
            abandonQuest()
            task.wait(0.5)
            acceptQuest(data.quest)
            currentQuest = data.quest
            task.wait(QUEST_COOLDOWN)
        end
        
        local target = getNearestTarget(data.mobs)
        if target then
            tweenToTarget(target)
            
            local attackStart = tick()
            while _G.AutoQuestEnabled and target and target.Parent and target:FindFirstChildOfClass("Humanoid") do
                local humanoid = target.Humanoid
                if humanoid.Health <= 0 then break end
                if tick() - attackStart > 45 then break end
                
                local root = target:FindFirstChild("HumanoidRootPart")
                if not root then break end
                
                local hrp = getHRP()
                hrp.CFrame = root.CFrame * CFrame.new(0, HEIGHT_OFFSET, 0)
                hrp.Velocity = Vector3.zero
                
                task.wait()
            end
            
            stopFloat()
        else
            stopFloat()
            task.wait(2)
        end
    end
    
    stopFloat()
end)

