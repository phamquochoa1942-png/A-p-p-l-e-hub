local function getCharacter()
    return LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
end

local function getHRP()
    local char = getCharacter()
    return char:WaitForChild("HumanoidRootPart")
end

local function getLevel()
    local success, data = pcall(function()
        return LocalPlayer.Data.Level.Value
    end)
    if success and type(data) == "number" then
        return data
    else
        local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
        if leaderstats then
            local lv = leaderstats:FindFirstChild("Level") or leaderstats:FindFirstChild("LVL")
            if lv then return lv.Value end
        end
        warn("[Apple Hub] Khong doc duoc Level")
        return 0
    end
end

local function getBestFarmData(level)
    for _, v in ipairs(FarmTable) do
        if level >= v.min and level <= v.max then
            return v
        end
    end
    return FarmTable[#FarmTable]
end

local function getNearbyTargets(mobList)
    local hrp = getHRP()
    local targets = {}
    local NPCs = workspace:FindFirstChild("NPCs")
    if not NPCs then return targets end
    
    for _, name in ipairs(mobList) do
        for _, mob in ipairs(NPCs:GetChildren()) do
            if mob:IsA("Model") and mob.Name == name then
                local humanoid = mob:FindFirstChildOfClass("Humanoid")
                local root = mob:FindFirstChild("HumanoidRootPart")
                if humanoid and humanoid.Health > 0 and root then
                    local dist = (hrp.Position - root.Position).Magnitude
                    if dist <= ATTACK_RANGE then
                        table.insert(targets, mob)
                    end
                end
            end
        end
    end
    return targets
end

local function getNearestTarget(mobList)
    local hrp = getHRP()
    local nearest = nil
    local minDist = math.huge
    
    local NPCs = workspace:FindFirstChild("NPCs")
    if not NPCs then return nil end
    
    for _, name in ipairs(mobList) do
        for _, mob in ipairs(NPCs:GetChildren()) do
            if mob:IsA("Model") and mob.Name == name then
                local humanoid = mob:FindFirstChildOfClass("Humanoid")
                local root = mob:FindFirstChild("HumanoidRootPart")
                if humanoid and humanoid.Health > 0 and root then
                    local dist = (hrp.Position - root.Position).Magnitude
                    if dist < minDist then
                        minDist = dist
                        nearest = mob
                    end
                end
            end
        end
    end
    return nearest
end

local function findNPC(questName)
    local nearest = nil
    local minDist = math.huge
    local hrp = getHRP()
    
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and string.find(obj.Name, questName) and obj:FindFirstChild("Head") then
            local root = obj:FindFirstChild("HumanoidRootPart") or obj.Head
            local dist = (hrp.Position - root.Position).Magnitude
            if dist < minDist then
                minDist = dist
                nearest = obj
            end
        end
    end
    return nearest
end

local function abandonQuest()
    pcall(function()
        local remote = ReplicatedStorage:FindFirstChild("RemoteEvents")
        if remote and remote:FindFirstChild("QuestAbandon") then
            remote.QuestAbandon:FireServer("repeatable")
        end
    end)
end

local function acceptQuest(questName)
    local NPC = findNPC(questName)
    if not NPC then return false end
    
    local hrp = getHRP()
    local npcRoot = NPC:FindFirstChild("HumanoidRootPart") or NPC.Head
    
    local dist = (hrp.Position - npcRoot.Position).Magnitude
    if dist > 50 then
        local time = math.clamp(dist / TWEEN_SPEED, 0.5, 3)
        local tween = TweenService:Create(hrp, TweenInfo.new(time, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            CFrame = npcRoot.CFrame * CFrame.new(0, 0, -5)
        })
        tween:Play()
        tween.Completed:Wait()
    else
        hrp.CFrame = npcRoot.CFrame * CFrame.new(0, 0, -5)
    end
    
    local prompt = NPC:FindFirstChildWhichIsA("ProximityPrompt")
    if prompt then
        fireproximityprompt(prompt)
        task.wait(0.5)
    end
    
    pcall(function()
        local remote = ReplicatedStorage:FindFirstChild("RemoteEvents")
        if remote and remote:FindFirstChild("QuestAccept") then
            remote.QuestAccept:FireServer(questName)
        end
    end)
    
    return true
end

local function startFloat()
    if isFloating then return end
    isFloating = true
    
    local hrp = getHRP()
    local bv = hrp:FindFirstChild("FloatBody")
    if not bv then
        bv = Instance.new("BodyVelocity")
        bv.Name = "FloatBody"
        bv.Velocity = Vector3.zero
        bv.MaxForce = Vector3.new(1e6, 1e6, 1e6)
        bv.Parent = hrp
    end
    
    if floatConnection then floatConnection:Disconnect() end
    floatConnection = RunService.Stepped:Connect(function()
        local char = getCharacter()
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                part.CanCollide = false
            end
        end
        hrp.Velocity = Vector3.zero
    end)
end

local function stopFloat()
    isFloating = false
    if floatConnection then
        floatConnection:Disconnect()
        floatConnection = nil
    end
    local hrp = getHRP()
    local bv = hrp:FindFirstChild("FloatBody")
    if bv then bv:Destroy() end
    
    local char = getCharacter()
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = true
        end
    end
end

local function tweenToTarget(target)
    local hrp = getHRP()
    local root = target:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    startFloat()
    
    local targetPos = root.Position + Vector3.new(0, HEIGHT_OFFSET, 0)
    local dist = (hrp.Position - targetPos).Magnitude
    
    if dist > 30 then
        local time = math.clamp(dist / TWEEN_SPEED, 0.3, 2)
        local tween = TweenService:Create(hrp, TweenInfo.new(time, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            CFrame = CFrame.new(targetPos)
        })
        tween:Play()
        tween.Completed:Wait()
    end
end

-- Hàm lấy part để đánh (ưu tiên HumanoidRootPart hoặc Torso)
local function GetTargetPart(mob)
    local parts = {"HumanoidRootPart", "Torso", "UpperTorso", "LowerTorso", "Head"}
    for _, partName in ipairs(parts) do
        local part = mob:FindFirstChild(partName)
        if part then
            return part
        end
    end
    return nil
end

